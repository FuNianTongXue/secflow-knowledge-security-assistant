SECFLOW_DATA_DIR=data

# Optional long-term memory. If unset, the service falls back to data/memory.json.
DATABASE_URL=postgresql://secflow:secflow@127.0.0.1:5432/secflow
# POSTGRES_DSN=postgresql://secflow:secflow@127.0.0.1:5432/secflow
SECFLOW_MEMORY_MAX_HISTORY=300
SECFLOW_MEMORY_RECENT_LIMIT=6
SECFLOW_MEMORY_RETRIEVAL_LIMIT=5
SECFLOW_MEMORY_CONTEXT_CHARS=3000

# Optional OpenAI-compatible LLM. DeepSeek is the default provider when DEEPSEEK_API_KEY is set.
SECFLOW_LLM_PROVIDER=deepseek
SECFLOW_LLM_ENDPOINT=https://api.deepseek.com/v1
SECFLOW_LLM_MODEL=deepseek-chat
SECFLOW_LLM_API_KEY=
SECFLOW_LLM_MAX_TOKENS=1800
SECFLOW_LLM_TEMPERATURE=0.25
SECFLOW_LLM_TIMEOUT_MS=60000
